{
  "expo": {
    "scheme": "goldenrainest",
    "name": "GOLDEN RAIN EST",
    "slug": "golden-rain-est",
    "version": "5.5.5",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/image.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.IMCBS.goldenrainest",
      "buildNumber": "13",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 12,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.IMCBS.goldenrainest",
      "edgeToEdgeEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "web": {
      "favicon": "./assets/image.jpeg"
    },
    "extra": {
      "eas": {
        "projectId": "340e3039-7252-4411-acf1-50491ba579ae"
      }
    }
  }
}